+static int cms_klee_cgats_variant = -1;
+static cmsUInt32Number cms_klee_cgats_pos = 0;
+
+static
+const char* cms_klee_cgats_selected(void)
+{
+    if (cms_klee_cgats_variant < 0)
+        cms_klee_cgats_variant = klee_range(0, 4, "transicc_r5_cgats_menu");
+
+    switch (cms_klee_cgats_variant) {
+    case 1: return cms_klee_cgats_menu[1];
+    case 2: return cms_klee_cgats_menu[2];
+    case 3: return cms_klee_cgats_menu[3];
+    default: return cms_klee_cgats_menu[0];
+    }
+}
+
+static
+cmsUInt32Number cms_klee_cgats_len(const char* text)
+{
+    cmsUInt32Number len = 0;
+    while (text[len] != '\0')
+        len++;
+    return len;
+}
+
+static
+cmsUInt8Number cms_klee_pin_cgats_byte(cmsUInt8Number value, cmsUInt32Number pos)
+{
+    const char* text = cms_klee_cgats_selected();
+    cmsUInt32Number len = cms_klee_cgats_len(text);
+    cmsUInt8Number expected = (pos < len) ? (cmsUInt8Number) text[pos] : (cmsUInt8Number) '\n';
+    klee_assume(value == expected);
+    return expected;
+}
