+   binary never sees the klee_range / klee_assume intrinsics. */
+#include <klee/klee.h>
+static const char *const gawk_klee_progs[] = {
+	"BEGIN{print \"hi\"}",
+	"BEGIN{x=3+4*2;print x}",
+	"BEGIN{print length(\"hello\")}",
+	"BEGIN{print substr(\"hello\",2,3)}",
