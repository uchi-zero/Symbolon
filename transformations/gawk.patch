+#ifdef KLEE_BITCODE
+	/* input-menu-pin: see the comment on gawk_klee_progs above. Pin the
+	   first SRC_FILE read (the symbolic awk program, file A) to one menu
+	   entry chosen by a symbolic klee_range; klee_assume + concretize so
+	   the lexer is fork-free and the ktest replays the exact program. */
+	{
+		static int gawk_klee_pinned = 0;
+
+		if (! gawk_klee_pinned && sourcefile->stype == SRC_FILE && n > 0) {
+			unsigned sel =
+				(unsigned) klee_range(0, GAWK_KLEE_NPROGS, "gawk_prog_sel");
+			const char *p = gawk_klee_progs[0];
+			unsigned k;
+			int plen = 0, i;
+
+			gawk_klee_pinned = 1;
+			/* concrete pointer in each forked state (no symbolic index) */
+			for (k = 1; k < (unsigned) GAWK_KLEE_NPROGS; k++)
+				if (sel == k)
+					p = gawk_klee_progs[k];
+			while (p[plen] != '\0')
+				plen++;
+			/* concretize all n read bytes: program text then '\n' padding */
+			for (i = 0; i < n; i++) {
+				char t = (i < plen) ? p[i] : '\n';
+				klee_assume(lexptr[i] == t);
+				lexptr[i] = t;
+			}
+		}
+	}
+#endif
 	return sourcefile->buf;
