+  "cd /;printf \"%d/%x\\n\" 9 255;umask 022;hash -r;type -t cd;declare -i n=2+3;echo $n\nexit\n",
+  "help cd>/dev/null;enable -n test;alias z=ls;unalias -a;kill -l 9;ulimit -t;hash -r;type -ta cd\nexit\n",
+  "a=(p q r);declare -A m;m[k]=1;echo ${a[1]} ${#a[@]} ${m[k]} ${!m[@]};mapfile -t b<<<$'x\\ny'\nexit\n",
+  "s=Hello.W;echo ${s,,} ${s^^} ${s/l/L} ${s:1:3} ${#s} ${s##*.} ${s%.*}\nexit\n",
+  "for i in 1 2;do echo $i;done;n=0;while ((n<2));do ((n++));done;until ((!n));do ((n--));done\nexit\n",
+  "f(){ local z=$1;return 7;};f hi;echo $?;g(){ echo $((2**8));};g;caller 0;times;let x=7%3\nexit\n",
+  "echo a{b,c}{1..3};case x in x)echo m;;esac;[[ ab == a* ]]&&echo y;test -d /&&echo d\nexit\n",
+  "x=$(echo sub);export E=v;echo $E $x;unset E;set -- a b;echo $# $1;shift;echo $*\nexit\n",
+  "p=\"a b|c;d\";IFS=\"|\" read x y<<<\"$p\";echo $x$y;v=${p// /_};echo ${v:0:5}${#v}\nexit\n",
+  "echo $(date +%s 2>/dev/null);echo `echo bt`;x=$((1+2*3));((x>5))&&echo $x;: $((x%4))\nexit\n",
+  "eval \"echo ev\";echo \"d$x\" 'l$x';trap \"echo t\" EXIT;{ echo g;}>/dev/null\nexit\n",
+  "printf '%5.2f|%-4s|%x|%o\\n' 3.14 hi 255 8;echo $((0x1F)) $((2#101)) $((~0))\nexit\n",
+  "pushd /tmp>/dev/null;dirs -v>/dev/null;popd>/dev/null;getopts ab o -a;shopt -s extglob\nexit\n",
+  "v=foobar;echo ${v:2} ${v: -3} ${v/o*o/_} ${v//o/0} ${v%%b*} ${v##*o};let 'q=7%3'\nexit\n"
