+enum { KLEE_BASH_NMENU = sizeof (klee_bash_menu) / sizeof (klee_bash_menu[0]) };
+static int klee_bash_sel_done = 0;
+static const char *klee_bash_prog = 0;
+static int klee_bash_off = 0;
