+/* Pin the just-read stdin bytes in BP to the next slice of one menu program,
+   chosen symbolically on the first call.  Only the primary script stdin
+   (fd 0); a one-shot symbolic selector, then a deterministic byte feed. */
+static void
+klee_bash_pin_stdin_menu (BUFFERED_STREAM *bp, ssize_t nr)
+{
+  int i, len;
+
+  if (bp->b_fd != 0 || nr <= 0)
+    return;
+
+  if (klee_bash_sel_done == 0)
+    {
+      unsigned sel, k;
+      klee_bash_sel_done = 1;
+      sel = (unsigned) klee_range (0, KLEE_BASH_NMENU, "bash_cmd_sel");
+      /* Concrete pointer in each forked state (no symbolic array index). */
+      klee_bash_prog = klee_bash_menu[0];
+      for (k = 1; k < (unsigned) KLEE_BASH_NMENU; k++)
+	if (sel == k)
+	  klee_bash_prog = klee_bash_menu[k];
+      klee_bash_off = 0;
+    }
+
+  len = 0;
+  while (klee_bash_prog[len] != '\0')
+    len++;
+
+  for (i = 0; i < (int) nr; i++)
+    {
+      if (klee_bash_off >= len)
+	break;			/* program fully fed; rest stays symbolic but is unreached past `exit' */
+      klee_assume (bp->b_buffer[i] == klee_bash_prog[klee_bash_off]);
+      bp->b_buffer[i] = klee_bash_prog[klee_bash_off];
+      klee_bash_off++;
+    }
+}
