+enum { BC_KLEE_NPROGS = sizeof (bc_klee_progs) / sizeof (bc_klee_progs[0]) };
+static int bc_klee_pinned = 0;
+static void
+bc_klee_input (char *buf, int *result, int max_size)
+{
+  int r;
+  while ((r = read (fileno (yyin), (char *) buf, max_size)) < 0)
+    if (errno != EINTR)
+      {
+	yyerror ("read() in flex scanner failed");
+	bc_exit (1);
+      }
+  if (!bc_klee_pinned && yyin == stdin && r > 0)
+    {
