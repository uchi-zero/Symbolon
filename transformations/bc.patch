+      const char *p = bc_klee_progs[0];
+      unsigned k;
+      int n = 0, i;
+      bc_klee_pinned = 1;
+      /* Concrete pointer in each forked state (no symbolic array index). */
+      for (k = 1; k < (unsigned) BC_KLEE_NPROGS; k++)
+	if (sel == k)
+	  p = bc_klee_progs[k];
+      while (p[n] != '\0')
+	n++;
+      if (n > r)
+	n = r;
+      for (i = 0; i < n; i++)
+	{
+	  klee_assume (buf[i] == p[i]);
+	  buf[i] = p[i];
+	}
+    }
+  *result = r;
+}
