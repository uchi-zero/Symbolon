+            n = ret;
+        for (i = 0; i < n; i++) {
+            klee_assume(start[i] == p[i]);
+            start[i] = p[i];
+        }
+        for (i = n; i < ret; i++) {
+            klee_assume(start[i] == ' ');
+            start[i] = ' ';
+        }
+    }
+#endif /* KLEE_BITCODE */
+
     return(ret);
 }
 
