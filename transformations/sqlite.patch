+/* v3 stdin-S_IFREG pin: called once at main() entry, BEFORE isatty(0). KLEE's
+** POSIX model only prefers S_IFREG for the symbolic stdin's st_mode, so without
+** this the isatty(0) check forks an S_IFCHR branch on which the shell goes
+** interactive and bails early. klee_assume((st_mode & S_IFMT)==S_IFREG) prunes
+** that fork so every searcher (not just min-distance ones) takes the deep
+** non-interactive path. */
+static void sqlite_klee_pin_stdin_regular(void){
+  struct stat st;
+  if( fstat(0, &st)==0 ){
+    klee_assume( (st.st_mode & S_IFMT)==S_IFREG );
+  }
