+/* Pin the symbolic stdin to one menu entry (once), then serve that single
+** line on the first call and EOF (NULL) thereafter. */
+static char *sqlite_klee_getline(char *zLine){
+  char buf[SQLITE_KLEE_STDIN_WIDTH];
+  const char *p;
+  unsigned sel, k;
+  int i, len;
+  ssize_t r;
+
+  if( sqlite_klee_done ){ free(zLine); return 0; }
+
+  /* Consume the symbolic stdin bytes so the ktest carries the pin. */
+  r = read(0, buf, SQLITE_KLEE_STDIN_WIDTH);
+  if( r < 0 ) r = 0;
