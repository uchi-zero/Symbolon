+#ifdef KLEE_BITCODE
+  /* input-menu-pin (transformations/path-explosion/input-menu-pin):
+   *
+   * Harness: "--sym-args 0 2 4 A B --sym-files 2 50".  KLEE reconstructs argv
+   * as { prog, [arg00], [arg01], "A", "B" } -- 0..2 leading symbolic option
+   * words of <=4 chars each, then the two concrete data-file names A and B
+   * whose 50-byte bodies are symbolic.  Left free, KLEE drowns in getopt_long
+   * and the df_get_next_record / dstrstr delimiter scan over the symbolic file
+   * bytes and never assembles a valid reference-matching invocation; the
+   * baseline plateaus near 920 lines with the data engine almost untouched
+   * (process_files.c 84/1670, hash.c 0/134, write_files.c 0/96).
+   *
+   * Remedy: pin the run to one of a menu of COMPLETE, VALID combine command
+   * lines, selected by a single symbolic klee_range.  Three pins per branch:
+   *   1. argc == 5 (the n_args == 2 branch), asserted BEFORE the menu fork so
+   *      the menu only forks on the surviving valid path (else every argc-3/4
+   *      state dies on the assume without doing work);
+   *   2. the two <=4-char option words (klee_assume on argv bytes) -- we
+   *      CONSTRAIN the real symbolic argv rather than overwrite the pointer, so
+   *      the ktest records the exact command line;
+   *   3. S_ISREG on each file's stat AND the 50-byte body.  The stat pin is
+   *      essential: without it KLEE leaves a file's st_mode symbolic and picks
+   *      S_IFCHR, so klee-replay materializes it as a pty instead of a disk
+   *      file and combine's fopen() of the reference file reads a 0-length tty
+   *      and dies with "File: Input/output error" -- losing all engine coverage
+   *      on replay.  Pinning S_ISREG makes klee-replay write both files to disk.
+   *
+   * KLEE forks once on the selector and drives every branch to a clean exit in
+   * ONE run (one bitcode, one manifest.json -- never a cross-run profraw union);
+   * the native cov binary (plain df_main, no KLEE_BITCODE) reproduces each
+   * engine path on replay.  Entries exercise distinct reachable features:
+   * reference key-match + check-all (-rB -R), count (-n), write-reference-output
+   * (-w, write_files.c), optional / exclude match (-p/-P), unique (-u), verbose
+   * (-v), flag (-f), hierarchy leaf-only / up-hierarchy (-l/-U), reference =
+   * file A vs B, and the join emulation (-e join).  Guarded by KLEE_BITCODE so
+   * the cov binary never sees the klee_range / klee_assume intrinsics. */
+  {
+    /* r5: MINIMAL 50-byte bodies.  r4 showed coverage of the dominant `-e join`
+     * branch comes almost entirely from handle_join_arguments + the shared
+     * engine setup (tiny 1-record data covers 1415 of join's 1432 lines), NOT
+     * from iterating many records.  Shrinking every entry's data to 1-2 tiny
+     * records keeps the per-branch coverage but makes each branch CHEAP to run
+     * to completion -- so breadth-first / empc can finish all branches of the
+     * wide fork within budget instead of stalling in a deep join (the r4
+     * regression: bfs/empc 1693/1640 -> 1352/1297 because the 28-branch fork
+     * starved the deep join).  Two tiny records, last field 'z'-padded so no
+     * empty/partial record trips a field-count check; the rest is trailing
+     * newlines (empty records combine reads and skips cheaply). */
+    static const char W1[50] = "a\nbz\n";
+    static const char W2[50] = "a\ncz\n";
+    static const char J1[50] = "a 1\n";   /* join: 1 matching record each (1415 lines) */
+    static const char J2[50] = "a 2\n";
+    static const char E1[50] = "\n\naz\n"; /* leading empty records (zero-length path) */
+    static const char E2[50] = "\n\nbz\n";
+    /* r22: hierarchy data to DRIVE traverse_hierarchy / hrchy_add_path (not just
+     * parse the -a option).  traverse_hierarchy fires only when -a gives a valid
+     * hierarchy-key range AND a data record MATCHES a reference key (keep_match
+     * == 1, hash_index != -1).  So both files must share a whole-record key.
+     * H1 (data, file A) and H2 (reference, file B) share the record "a b" so the
+     * match succeeds; field 1 (-a1) is the hierarchy key. */
+    static const char H1[50] = "a b\n";
+    static const char H2[50] = "a b\n";
+    /* r23: multi-field MATCHING data to drive write_match_record's output loop.
+     * M1 (data, file A) and M2 (reference, file B) share key field "a" and carry
+     * extra fields, so a -o1 (data output field 1) match writes fields through
+     * the gi_data_out_range_count>0 branch (581 uncovered regions in
+     * write_match_record). Space-delimited (combine's default field delimiter). */
+    static const char M1[50] = "a x y\nb p q\n";
+    static const char M2[50] = "a x y\nb p q\n";
+    /* r24: data-side -p (before -r) sets gi_data_optional_ind; -rB then binds a
+     * reference whose record "q r s" the data "a m n" never matches, so the
+     * unmatched-reference optional-write loop (process_files.c 499-512) fires. */
+    static const char P1[50] = "a m n\n";
+    static const char P2[50] = "a m n\nq r s\n";
+
+    struct combine_menu_entry {
+      const char *o0;
+      const char *o1;
+      const char *a;
+      const char *b;
+    };
+    /* r3: ordered by descending UNIQUE (disjoint) coverage, richest first.
+     * The single klee_range fork is explored by each searcher in a different,
+     * scheduling-dependent order before the 10-min plateau; r1/r2 showed bfs
+     * could miss the dominant `-e join` branch entirely (banking ~1005) while
+     * a luckier searcher that hit join banked ~1497.  Front-loading the
+     * high-unique-coverage branches (join ~1432, then the engine, then the cut
+     * / M / empty error-and-edge paths) makes greedy (nurs:md2u) and
+     * breadth-first (bfs) searchers reach the big slices early instead of
+     * exhausting budget on the redundant `-rB -*` family (each ~830 lines,
+     * heavily overlapping).  The redundant family is kept but moved last so a
+     * searcher that does sweep still gets their small marginal lines. */
+    static const struct combine_menu_entry combine_menu[] = {
+      { "-e", "join", J1, J2 },  /* richest single entry (~1432): join engine    */
+      { "-rB", "-a1", H1, H2 },  /* r22: hierarchy MATCH+traverse (traverse_hierarchy/hrchy_add_path) */
+      { "-rB", "-o1", M1, M2 },  /* r23: matched multi-field output (write_match_record output loop) */
+      { "-rB", "-O1", M1, M2 },  /* r23b: output-field RANGE on matched data (gi_data_out_range_count loop) */
+      { "-rB", "-s1", M1, M2 },  /* r23b: sum field on matched multi-field data (sum/counter write path) */
+      { "-p", "-rB", P1, P2 },   /* r24: data -p + reference -> unmatched-ref optional WRITE (process_files.c 499-512) */
+      { "-rA", "-rB", M1, M2 },  /* r25: TWO reference files -> process_data_reference_matches recursion (+4) */
+      { "-P", "-rB", M1, M2 },   /* r25: data-side -P exclude (before -r) -> gi_data_exclude_match_ind write-suppression (+2) */
+      { "-rB", "-v", W1, W2 },   /* reference key-match + verbose request dump    */
+      { "-rB", "-w", W1, W2 },   /* write reference output (write_files.c)        */
+      { "-e", "cut", W1, W2 },   /* cut emulation arg-parse (handle_cut_arguments)*/
