+       * record-length, output-file, constant, hash/counter-size parsing the
+       * earlier menu never touched.  Ordered by descending unique coverage
+       * (offline union 1689 -> ~1857, +168).  Some terminate via FATAL_ERROR
+       * (still emit a ktest exercising the parse + error report). */
+      { "-rB", "-o9", W1, W2 },  /* output-field range parse (calculate_ranges)   */
+      { "-rB", "-L9", W1, W2 },  /* input-record-length parse                     */
+      { "-rB", "-s9", W1, W2 },  /* sum-field range parse                         */
+      { "-rB", "-B.", W1, W2 },  /* input-record-delimiter parse                  */
+      { "-rB", "-D.", W1, W2 },  /* input-field-delimiter parse                   */
+      { "-rB", "-O9", W1, W2 },  /* field-order spec parse (parse field order)    */
+      { "-rB", "-tA", W1, W2 },  /* output-file open path                         */
+      { "-rB", "-Kx", W1, W2 },  /* output-constant string                        */
+      { "-rB", "-h9", W1, W2 },  /* hash-size parse                               */
+      { "-rB", "-z9", W1, W2 },  /* counter-size parse                            */
+      { "-rB", "-d.", W1, W2 },  /* output-field-delimiter parse                  */
+      { "-rB", "-b.", W1, W2 },  /* output-record-delimiter parse                 */
+      /* r5: the remaining single-option-argument parse branches (key / data-key
+       * / hierarchy-key field-range parse, emulation-arg dispatch error,
+       * hash-movement, extension, counter).  Each 2 words; offline union
+       * 1857 -> ~1996. */
+      { "-rB", "-e9", W1, W2 },  /* emulate-arg dispatch (unknown emulation error)*/
+      { "-rB", "-a9", W1, W2 },  /* hierarchy-key field-range parse               */
+      { "-rB", "-k9", W1, W2 },  /* key-fields range parse                        */
+      { "-rB", "-m9", W1, W2 },  /* data-key-fields range parse                   */
+      { "-rB", "-H9", W1, W2 },  /* hash-movement option                          */
+      { "-rB", "-x9", W1, W2 },  /* extension option                              */
+      { "-rB", "-X9", W1, W2 },  /* extension-init-file option                    */
+      { "-rB", "-F9", W1, W2 },  /* flatten-hierarchy option                      */
+      { "-rB", "-P", W1, W2 },   /* exclude match                                 */
+      { "-rB", "-U", W1, W2 },   /* up-hierarchy                                  */
+      { "-rB", "-p", W1, W2 },   /* optional match                                */
+      { "-rB", "-l", W1, W2 },   /* hierarchy leaf-only                           */
+      { "-rB", "-u", W1, W2 },   /* unique keys                                   */
+      { "-rB", "-n", W1, W2 },   /* count                                         */
+      { "-rB", "-R", W1, W2 },   /* check-all-reference                           */
+      { "-rB", "-f", W1, W2 },   /* flag                                          */
+      { "-rA", "-R", W1, W2 },   /* reference=A key-match + check-all             */
+      { "-rA", "-n", W1, W2 },   /* reference=A count                             */
+    };
+    enum { COMBINE_NMENU = sizeof (combine_menu) / sizeof (combine_menu[0]) };
+
+    /* Pin argc to the n_args==2 branch FIRST, so the menu fork only happens on
+     * the surviving valid path. */
+    klee_assume (argc == 5);
+
+    {
+      unsigned sel = (unsigned) klee_range (0, COMBINE_NMENU, "combine_menu_sel");
+      const struct combine_menu_entry *e = &combine_menu[0];
+      unsigned mk;
+      struct stat stbuf;
+      for (mk = 1; mk < (unsigned) COMBINE_NMENU; mk++)
+	if (sel == mk)
+	  e = &combine_menu[mk];
+
+      /* Constrain the two symbolic option words to this entry's bytes. */
+      {
+	const char *w = e->o0;
+	int i;
+	for (i = 0; w[i] != '\0'; i++)
+	  klee_assume (argv[1][i] == w[i]);
+	klee_assume (argv[1][i] == '\0');
+      }
+      {
+	const char *w = e->o1;
+	int i;
+	for (i = 0; w[i] != '\0'; i++)
+	  klee_assume (argv[2][i] == w[i]);
+	klee_assume (argv[2][i] == '\0');
+      }
+
+      /* Pin both files to regular-file stat so klee-replay writes them to disk
+       * (not a pty), then pin the 50-byte bodies so the ktest replays exactly. */
+      if (stat ("A", &stbuf) == 0) klee_assume (S_ISREG (stbuf.st_mode));
+      if (stat ("B", &stbuf) == 0) klee_assume (S_ISREG (stbuf.st_mode));
+      {
+	int fd = open ("A", O_RDONLY);
+	if (fd >= 0) {
+	  unsigned char buf[50];
+	  int n = read (fd, buf, 50);
+	  int j;
+	  close (fd);
+	  if (n == 50)
+	    for (j = 0; j < 50; j++)
+	      klee_assume (buf[j] == (unsigned char) e->a[j]);
+	}
+      }
+      {
+	int fd = open ("B", O_RDONLY);
+	if (fd >= 0) {
+	  unsigned char buf[50];
+	  int n = read (fd, buf, 50);
+	  int j;
+	  close (fd);
+	  if (n == 50)
+	    for (j = 0; j < 50; j++)
+	      klee_assume (buf[j] == (unsigned char) e->b[j]);
+	}
+      }
+    }
+  }
