+#ifdef KLEE_BITCODE
+    /* r11: 2-entry termcap file (33 bytes content + 67 bytes newline pad).
+     * Entry 1 (`b|t:co#80:cm=\E[%p1%dH:`) supplies cols + parameterized
+     * cursor-motion. Entry 2 (`a|s:tc=b:`) references entry 1 via the
+     * termcap `tc=` clause, driving _nc_resolve_uses2's resolution +
+     * merge stages. The `\n` between entries is the entry separator. */
+    if (tmp_fp != NULL) {
+	static const char r11_entries[] =
+	    "b|t:co#80:cm=\\E[%p1%dH:\na|s:tc=b:";  /* 33 bytes */
+	const int prefix_len = (int)(sizeof r11_entries - 1);
+	int i;
+	for (i = 0; i < prefix_len; i++) {
+	    int ch = fgetc(tmp_fp);
+	    if (ch == EOF) break;
+	    klee_assume((unsigned char)ch == (unsigned char)r11_entries[i]);
+	}
+	for (; i < 100; i++) {
+	    int ch = fgetc(tmp_fp);
+	    if (ch == EOF) break;
+	    klee_assume((unsigned char)ch == (unsigned char)'\n');
+	}
