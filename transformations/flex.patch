+/* Select the menu entry for this run and arm the YY_INPUT pin. We peek the
+   symbolic input file to confirm a symbolic run, rewind, pin its stat to a
+   regular file (so klee-replay materialises a real file, not a pty -- see
+   below), then pick a menu entry with one symbolic klee_range. The actual
+   byte pinning + CONCRETIZATION happens in scan.l's YY_INPUT as the scanner
+   reads, so flexscan's DFA-table reads use concrete indices (the round-1
+   approach left them symbolic and went solver-bound). Guarded by
+   klee_is_symbolic so the build-time bootstrap (stage1flex reading the
+   concrete scan.l) is untouched. */
+static void
+flex_klee_pin_input (void)
+{
+	int first;
+
+	if (yyin == NULL)
+		return;
+
+	first = getc (yyin);
+	if (!klee_is_symbolic (first)) {
+		if (first != EOF) {
+			if (fseek (yyin, 0, SEEK_SET) != 0)
+				rewind (yyin);
+		}
+		return;
+	}
+
+	/* Rewind the peeked byte so YY_INPUT reads the file from the top. */
+	if (fseek (yyin, 0, SEEK_SET) != 0)
+		rewind (yyin);
+
+	{
+		/* Pin the symbolic file's stat to a regular file. KLEE's POSIX model
+		   only *prefers* (klee_prefer_cex) S_IFREG for a symbolic file's
+		   st_mode, so flex's isatty(fileno(yyin)) call (in yy_create_buffer)
+		   forks a feasible branch where A is a character device; klee-replay
+		   then materialises that ktest as a pty and flex's interactive getc
+		   loop fails on replay. A hard assume removes the char-device branch. */
+		struct stat klee_st;
+		if (fstat (fileno (yyin), &klee_st) == 0)
+			klee_assume ((klee_st.st_mode & S_IFMT) == S_IFREG);
+	}
+
