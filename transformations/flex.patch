+		/* r18: CLI-option-dispatch mode -> the run's purpose is the option
+		   switch, not the spec. Pin a single fixed valid spec (no klee_range
+		   fork), so this mode stays a single state per flag bundle. */
+		flex_klee_spec = "%%\n[a-z]+ ;\n[0-9]+ ;\n. ;\n";
+		flex_klee_symbolic_run = 1;
+		return;
+	}
