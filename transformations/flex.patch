+	if (mode == 1) {
+		klee_assume (argc == 3);
+		flex_klee_pin_arg (argv[1], "--tables-f");
+		flex_klee_pin_arg (argv[2], "A");
+		flex_klee_tables_mode = 1;   /* r17: couple to a table-mode spec */
+		return;
+	}
+	if (mode == 2) {
+		klee_assume (argc == 2);
+		flex_klee_pin_arg (argv[1], "--help");
+		return;
+	}
+	if (mode == 3) {
+		klee_assume (argc == 2);
+		flex_klee_pin_arg (argv[1], "-?");
+		return;
+	}
+	if (mode == 4) {
+		klee_assume (argc == 2);
+		flex_klee_pin_arg (argv[1], "--version");
+		return;
+	}
+	if (mode == 5) {
+		klee_assume (argc == 3);
+		flex_klee_pin_arg (argv[1], "-T");
+		flex_klee_pin_arg (argv[2], "A");
+		return;
+	}
+	if (mode == 6) {
+		klee_assume (argc == 3);
+		flex_klee_pin_arg (argv[1], "-+");
+		flex_klee_pin_arg (argv[2], "A");
+		return;
+	}
