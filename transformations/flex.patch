+flex_klee_pin_arg (char *arg, const char *tok)
+{
+	size_t i;
+	for (i = 0; ; ++i) {
+		klee_assume (arg[i] == tok[i]);
+		arg[i] = tok[i];
+		if (tok[i] == '\0')
