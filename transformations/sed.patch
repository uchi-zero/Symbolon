+#ifdef KLEE_BITCODE
+#include <klee/klee.h>
+/* input-menu-pin companion (see sed.c).  libc getdelim scans the symbolic input
+   for the delimiter and forks on every possible newline position -- the dominant
+   fork site (66k self-forks, r2 profiling).  Replace it with a fork-free reader
+   under KLEE: pull raw bytes with getc (the file size is concrete under
+   --sym-files, so EOF does not fork) and pin each symbolic byte to a fixed
+   template, by absolute offset so an embedded delimiter cleanly splits lines.
+   The delimiter test is concrete every byte and never forks; klee_assume records
+   the bytes on the symbolic object (the cov binary replays the same input).
+
+   r5: the template is PER-SCRIPT -- sed.c fills the concrete buffer
+   `sed_klee_input_buf` (length `sed_klee_input_len`) for the menu entry pinned
+   this run, so each script sees input crafted to drive its own match / cycle
+   branches (digits for [0-9], four short lines for line-address commands, ...),
+   reaching more regexec.c DFA transitions without widening the menu.  The buffer
+   holds CONCRETE bytes (copied byte-by-byte in the selected fork) so the
+   klee_assume below actually pins the symbolic input object.  Falls back to a
+   default if the buffer is empty (a read before main's pin). */
+extern char sed_klee_input_buf[16];
+extern int  sed_klee_input_len;
+static size_t sed_klee_off = 0;
+static ssize_t
+sed_klee_getline (char **text, size_t *buflen, char delim, FILE *stream)
+{
+  static const char dflt[] = "aa.A1\nbbc";
+  const char *tmpl;
+  size_t tlen;
+  ssize_t n = 0;
+  int raw;
+
+  if (sed_klee_input_len > 0)
+    {
+      tmpl = sed_klee_input_buf;
+      tlen = (size_t) sed_klee_input_len;
+    }
+  else
+    {
+      tmpl = dflt;
+      tlen = sizeof (dflt) - 1;
+    }
+
+  if (*text == NULL || *buflen == 0)
+    {
+      *buflen = 128;
+      *text = xmalloc (*buflen);
+    }
+
+  while ((raw = getc (stream)) != EOF)
+    {
+      char c = tmpl[sed_klee_off++ % tlen];
+      /* Pin this input byte to the template before anything inspects it: the
+         assume constrains the symbolic object (so the ktest replays these exact
+         bytes), and the concrete c kept in the buffer means the delimiter test
+         below is concrete and never forks. */
+      klee_assume ((char) raw == c);
+      if ((size_t) n + 2 > *buflen)
+        {
+          *buflen *= 2;
+          *text = xrealloc (*text, *buflen);
+        }
+      (*text)[n++] = c;
+      if (c == delim)
+        break;
+    }
+
+  if (n == 0)
+    return -1;                 /* EOF with nothing read */
+  (*text)[n] = '\0';
+  return n;
+}
+#endif
+
 ssize_t
 ck_getdelim (char **text, size_t *buflen, char delim, FILE *stream)
 {
   if (ferror (stream))
     panic (_("read error on %s"), utils_fp_name (stream));
 
+#ifdef KLEE_BITCODE
+  ssize_t result = sed_klee_getline (text, buflen, delim, stream);
+#else
   ssize_t result = getdelim (text, buflen, delim, stream);
+#endif
   if (ferror (stream)) /* implies result < 0, hence errno is set */
     panic (_("read error on %s: %s"), utils_fp_name (stream), strerror (errno));
 
