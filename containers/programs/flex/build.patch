--- a/src/flexdef.h
+++ b/src/flexdef.h
@@ -1070,7 +1070,16 @@
 /* For setjmp/longjmp (instead of calling exit(2)). Linkage in main.c */
 extern jmp_buf flex_main_jmp_buf;

+/* In the KLEE bitcode build the longjmp model is unsupported, so we exit
+ * directly to keep symbolic states alive. In the instrumented concrete
+ * build (which klee-replay invokes for coverage) we keep the longjmp so
+ * exit happens cleanly from main(), avoiding atexit-handler corruption of
+ * LLVM's profile counters when FLEX_EXIT fires deep in the parser stack. */
+#ifdef SYMBOLON_KLEE_BITCODE
+#define FLEX_EXIT(status) exit(status)
+#else
 #define FLEX_EXIT(status) longjmp(flex_main_jmp_buf,(status)+1)
+#endif

 /* Removes all \n and \r chars from tail of str. returns str. */
 extern char *chomp (char *str);
